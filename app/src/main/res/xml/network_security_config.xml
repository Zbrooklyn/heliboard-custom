<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Pin certificates for HuggingFace model downloads -->
    <domain-config>
        <domain includeSubdomains="true">huggingface.co</domain>
        <pin-set expiration="2027-01-01">
            <!-- HuggingFace uses Let's Encrypt / Cloudflare certs -->
            <!-- ISRG Root X1 (Let's Encrypt) -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
            <!-- Backup: DigiCert Global Root G2 (Cloudflare) -->
            <pin digest="SHA-256">i7WTqTvh0OioIruIfFR4kMPnBqrS2rdiVPl/s2uC/CY=</pin>
        </pin-set>
    </domain-config>

    <!-- Pin for OpenAI API -->
    <domain-config>
        <domain includeSubdomains="true">api.openai.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- DigiCert Global Root G2 -->
            <pin digest="SHA-256">i7WTqTvh0OioIruIfFR4kMPnBqrS2rdiVPl/s2uC/CY=</pin>
            <!-- Backup: Baltimore CyberTrust Root -->
            <pin digest="SHA-256">Y9mvm0exBk1JoQ57f9Vm28jKo5lFm/woKcVxrYxu80o=</pin>
        </pin-set>
    </domain-config>

    <!-- Pin for Google Gemini API -->
    <domain-config>
        <domain includeSubdomains="true">generativelanguage.googleapis.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- GTS Root R1 (Google Trust Services) -->
            <pin digest="SHA-256">hxqRlPTu1bMS/0DITB1SSu0vd4u/8l8TjPgfaAp63Gc=</pin>
            <!-- Backup: GlobalSign Root CA -->
            <pin digest="SHA-256">K87oWBWM9UZfyddvDfoxL+8lpNyoUB2ptGtn0fv6G2Q=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
