<?xml version="1.0" encoding="utf-8"?>
<!--
    Samsung-style keyboard resize mode overlay.
    Shows blue border, center drag handle, edge tabs, Reset/Done buttons.
    SPDX-License-Identifier: Apache-2.0 AND GPL-3.0-only
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resize_mode_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <!-- Semi-transparent scrim to dim keyboard keys -->
    <View
        android:id="@+id/resize_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- Top edge grab tab -->
    <View
        android:id="@+id/resize_top_tab"
        android:layout_width="48dp"
        android:layout_height="6dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="0dp" />

    <!-- Left edge grab tab -->
    <View
        android:id="@+id/resize_left_tab"
        android:layout_width="6dp"
        android:layout_height="48dp"
        android:layout_gravity="start|center_vertical" />

    <!-- Right edge grab tab -->
    <View
        android:id="@+id/resize_right_tab"
        android:layout_width="6dp"
        android:layout_height="48dp"
        android:layout_gravity="end|center_vertical" />

    <!-- Center drag handle — blue circle with 4-arrow icon -->
    <ImageView
        android:id="@+id/resize_drag_handle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_resize_drag"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:contentDescription="@string/resize_keyboard"
        android:importantForAccessibility="yes" />

    <!-- Reset + Done buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/resize_reset_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="@string/resize_keyboard_reset"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/resize_done_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="@string/resize_keyboard_done"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
