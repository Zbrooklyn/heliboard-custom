<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical" >

    <include
        android:id="@+id/strip_container"
        layout="@layout/strip_container" />

    <!-- Drag handle for Samsung-style keyboard height resize.
         A thin pill-shaped bar users drag up/down to resize the keyboard. -->
    <View
        android:id="@+id/keyboard_resize_handle"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@string/resize_keyboard"
        android:visibility="gone" />

    <!-- To ensure that key preview popup is correctly placed when the current system locale is
         one of RTL locales, layoutDirection="ltr" is needed in the SDK version 17+. -->
    <helium314.keyboard.latin.KeyboardWrapperView
        android:id="@+id/keyboard_view_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="ltr" >

        <helium314.keyboard.keyboard.MainKeyboardView
            android:id="@+id/keyboard_view"
            android:layoutDirection="ltr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <include
            android:id="@+id/emoji_palettes_view"
            layout="@layout/emoji_palettes_view" />
        <include
            android:id="@+id/clipboard_history_view"
            layout="@layout/clipboard_history_view" />
        <helium314.keyboard.latin.suggestions.FeatureDrawerView
            android:id="@+id/feature_drawer_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:padding="8dp" />
        <helium314.keyboard.latin.voice.VoiceInputModeView
            android:id="@+id/voice_input_mode_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:padding="16dp" />

        <include
            android:id="@+id/resize_mode_overlay"
            layout="@layout/resize_mode_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_stop_one_handed_mode"
            android:contentDescription="@string/label_stop_onehanded_mode_key"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:scaleType="fitCenter"
            style="?attr/suggestionWordStyle" />

        <ImageButton
            android:id="@+id/btn_switch_one_handed_mode"
            android:contentDescription="@string/label_switch_onehanded_key"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:scaleType="fitCenter"
            style="?attr/suggestionWordStyle" />

        <ImageButton
            android:id="@+id/btn_resize_one_handed_mode"
            android:contentDescription="@string/label_resize_onehanded_key"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:scaleType="fitCenter"
            style="?attr/suggestionWordStyle" />

    </helium314.keyboard.latin.KeyboardWrapperView>

</LinearLayout>
