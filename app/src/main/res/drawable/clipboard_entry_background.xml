<?xml version="1.0" encoding="utf-8"?>
<!--
    SPDX-License-Identifier: GPL-3.0-only
    Clipboard card background — softer corners than keyboard keys (14dp vs 8dp),
    with a subtle border for depth on AMOLED dark backgrounds.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state: slightly brighter border for feedback -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
    <!-- Default state: subtle border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#12FFFFFF" />
        </shape>
    </item>
</selector>
